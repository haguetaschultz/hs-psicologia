---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteLinks } from "../config/site";
import { siteContent } from "../data/siteContent";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const getPostSlug = (id: string) => id.replace(/\.md$/, "");

const { agenda: agendaUrl, whatsapp: whatsappUrl } = siteLinks;
---

<BaseLayout>
  <main>
    <section class="hero" id="inicio">
      <div class="hero-content">
        <p class="eyebrow">{siteContent.hero.eyebrow}</p>
        <h1>Escuta humana com <em>embasamento</em> científico.</h1>
        <p class="hero-text">{siteContent.hero.description}</p>
        <p class="hero-focus">{siteContent.hero.focus}</p>
        <div class="hero-actions">
          <a class="button primary hero-primary" href={agendaUrl} target="_blank" rel="noopener">{siteContent.hero.primaryCta}</a>
          <a class="button secondary" href={whatsappUrl} target="_blank" rel="noopener">{siteContent.hero.secondaryCta}</a>
        </div>
      </div>

      <div class="hero-visual" aria-label="Identidade visual Hag Schultz Psicóloga">
        <img src="/assets/logo-hag-schultz.png" alt={siteContent.hero.imageAlt} />
        <aside class="quote-card">
          <span aria-hidden="true">“</span>
          <p>{siteContent.hero.quote}</p>
        </aside>
      </div>
    </section>

    <section class="section intro" id="sobre">
      <div class="section-heading">
        <p class="eyebrow">{siteContent.about.eyebrow}</p>
        <h2>{siteContent.about.title}</h2>
      </div>
      <div class="intro-layout">
        <figure class="intro-photo">
          <img src="/images/Hag_08_21-8.jpg" alt={siteContent.about.imageAlt} loading="lazy" decoding="async" />
        </figure>
        <div class="intro-copy">
          {siteContent.about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          <p class="professional-id">{siteContent.about.crp}</p>
        </div>
      </div>
    </section>

    <section class="section services" id="psicoterapia">
      <div class="section-heading compact">
        <h2>{siteContent.services.title}</h2>
        <p class="section-lead">{siteContent.services.lead}</p>
      </div>

      <div class="service-grid">
        {siteContent.services.cards.map((card, index) => (
          <article class="service-card">
            <span class="service-number">{String(index + 1).padStart(2, "0")}</span>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section approach" id="abordagem">
      <div class="approach-inner">
        <div>
          <p class="eyebrow">{siteContent.approach.eyebrow}</p>
          <h2>{siteContent.approach.title}</h2>
        </div>
        <div class="approach-copy">
          {siteContent.approach.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          <a class="text-link" href="#sobre">{siteContent.approach.linkLabel}</a>
        </div>
      </div>
    </section>

    <section class="section companies" id="empresas">
      <div class="section-heading">
        <p class="eyebrow">{siteContent.companies.eyebrow}</p>
        <h2>{siteContent.companies.title}</h2>
      </div>
      <p class="section-lead">{siteContent.companies.lead}</p>

      <div class="feature-list">
        {siteContent.companies.cards.map((card) => (
          <article>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
        <article class="feature-support">
          <p>{siteContent.companies.support}</p>
        </article>
      </div>

      <a class="button primary" href={whatsappUrl} target="_blank" rel="noopener">{siteContent.companies.cta}</a>
    </section>

    <section class="section content-section" id="conteudos">
      <div class="section-heading compact">
        <h2>{siteContent.contents.title}</h2>
        <p class="section-lead">{siteContent.contents.lead}</p>
      </div>
      <div class="content-grid">
        {posts.map((post) => (
          <article>
            <a class="content-card-link" href={`/conteudos/${getPostSlug(post.id)}/`}>
              <p class="content-tag">{post.data.category}</p>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <span>Ler conteúdo</span>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="section faq" id="perguntas">
      <div class="section-heading compact">
        <p class="eyebrow">{siteContent.faq.eyebrow}</p>
        <h2>{siteContent.faq.title}</h2>
      </div>

      <div class="faq-list">
        {siteContent.faq.items.map((item) => (
          <details>
            <summary>{item.question}</summary>
            {item.answers.map((answer) => <p>{answer}</p>)}
          </details>
        ))}
      </div>
    </section>

    <section class="section schedule" id="agenda">
      <div class="schedule-intro">
        <p class="eyebrow">{siteContent.schedule.eyebrow}</p>
        <h2>{siteContent.schedule.title}</h2>
        {siteContent.schedule.intro.map((paragraph) => <p>{paragraph}</p>)}
      </div>

      <div class="appointment-grid">
        {siteContent.schedule.cards.map((card) => (
          <article>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>

      <div class="schedule-actions">
        <a class="button primary" href={agendaUrl} target="_blank" rel="noopener">{siteContent.schedule.cta}</a>
      </div>
    </section>

    <section class="section final-cta" aria-labelledby="cta-title">
      <div class="final-cta-copy">
        <h2 id="cta-title">{siteContent.finalCta.title}</h2>
        <p>{siteContent.finalCta.lead}</p>
        <ul class="check-list">
          {siteContent.finalCta.bullets.map((bullet) => <li>{bullet}</li>)}
        </ul>
      </div>
      <aside class="next-step-card">
        <p class="eyebrow">{siteContent.finalCta.nextStepEyebrow}</p>
        <h3>{siteContent.finalCta.nextStepTitle}</h3>
        <p>{siteContent.finalCta.nextStepText}</p>
        <a class="button primary light" href={agendaUrl} target="_blank" rel="noopener">{siteContent.finalCta.nextStepCta}</a>
      </aside>
    </section>
  </main>
</BaseLayout>
