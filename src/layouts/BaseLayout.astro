---
import "../styles/global.css";
import { siteLinks } from "../config/site";
import { siteContent } from "../data/siteContent";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "HS Psicóloga | Hag Schultz",
  description = "HS Psicóloga: psicoterapia para adultos, saúde mental no trabalho e agenda online."
} = Astro.props;

const {
  agenda: agendaUrl,
  whatsapp: whatsappUrl,
  instagram: instagramUrl,
  linkedin: linkedinUrl,
  email
} = siteLinks;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/assets/logo-simbolo-redondo.png" />
  </head>
  <body>
    <header class="site-header" data-header>
      <a class="brand" href="/#inicio" aria-label="Hag Schultz Psicóloga - início">
        <img class="brand-symbol" src="/assets/logo-simbolo-redondo.png" alt="" />
        <span class="brand-text">
          <strong>Hag Schultz</strong>
          <small>Psicóloga | CRP 03/34978</small>
        </span>
      </a>

      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-menu" data-menu-toggle>
        <span></span>
        <span></span>
        <span></span>
        <span class="sr-only">Abrir menu</span>
      </button>

      <nav class="site-nav" id="site-menu" data-menu>
        <a href="/#inicio">Início</a>
        <a href="/#sobre">Sobre mim</a>
        <a href="/#psicoterapia">Psicoterapia</a>
        <a href="/#empresas">Empresas</a>
        <a href="/#conteudos">Conteúdos</a>
        <a href="/#perguntas">Perguntas frequentes</a>
        <a href="/#agenda" class="nav-cta">Agendar atendimento</a>
      </nav>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="footer-column footer-about">
        <h2>{siteContent.footer.brand}</h2>
        <p>{siteContent.footer.description}</p>
        <p>{siteContent.footer.crp}</p>
      </div>

      <nav class="footer-column footer-links" aria-label="Navegação do rodapé">
        <h2>{siteContent.footer.navTitle}</h2>
        <a href="/#inicio">Início</a>
        <a href="/#sobre">Sobre mim</a>
        <a href="/#psicoterapia">Psicoterapia</a>
        <a href="/#empresas">Empresas</a>
        <a href="/#conteudos">Conteúdos</a>
        <a href="/#perguntas">Perguntas frequentes</a>
        <a href={agendaUrl} target="_blank" rel="noopener">Agenda</a>
      </nav>

      <div class="footer-column footer-contact">
        <h2>{siteContent.footer.contactTitle}</h2>
        <a href={`mailto:${email}`}>{email}</a>
        <a href={whatsappUrl} target="_blank" rel="noopener">WhatsApp</a>
        <a href={instagramUrl} target="_blank" rel="noopener">@hag.psicologia</a>
        <a href={linkedinUrl} target="_blank" rel="noopener">LinkedIn</a>
        <p>{siteContent.footer.onlineAndInPerson}</p>
      </div>

      <div class="footer-note">
        <p>{siteContent.footer.copyright}</p>
        <p>{siteContent.footer.ethics}</p>
      </div>
    </footer>

    <a class="whatsapp-float" href={whatsappUrl} target="_blank" rel="noopener" aria-label="Falar pelo WhatsApp" title="Falar pelo WhatsApp">
      <svg aria-hidden="true" viewBox="0 0 32 32" focusable="false">
        <path d="M16.04 4C9.43 4 4.07 9.35 4.07 15.93c0 2.1.55 4.15 1.6 5.96L4 28l6.28-1.64a12.02 12.02 0 0 0 5.76 1.47h.01c6.6 0 11.96-5.35 11.96-11.93C28 9.35 22.64 4 16.04 4Zm0 21.8h-.01c-1.8 0-3.57-.48-5.12-1.39l-.37-.22-3.73.97 1-3.62-.24-.37a9.8 9.8 0 0 1-1.48-5.24c0-5.47 4.46-9.91 9.95-9.91 2.66 0 5.16 1.03 7.04 2.9a9.84 9.84 0 0 1 2.91 7c0 5.46-4.46 9.9-9.95 9.9Zm5.45-7.41c-.3-.15-1.77-.87-2.04-.97-.28-.1-.48-.15-.68.15-.2.3-.78.97-.96 1.17-.18.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48a8.96 8.96 0 0 1-1.66-2.06c-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.03-.52-.07-.15-.68-1.63-.93-2.24-.24-.59-.5-.5-.68-.51h-.58c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.22 3.08c.15.2 2.1 3.2 5.1 4.48.71.3 1.27.49 1.7.63.71.23 1.36.2 1.88.12.57-.08 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.13-.27-.2-.57-.35Z" />
      </svg>
    </a>

    <script>
      const menuToggle = document.querySelector("[data-menu-toggle]");
      const menu = document.querySelector("[data-menu]");
      const menuLinks = document.querySelectorAll("[data-menu] a");

      function closeMenu() {
        menu?.classList.remove("is-open");
        document.body.classList.remove("menu-open");
        menuToggle?.setAttribute("aria-expanded", "false");
      }

      menuToggle?.addEventListener("click", () => {
        const isOpen = menu?.classList.toggle("is-open");
        document.body.classList.toggle("menu-open", Boolean(isOpen));
        menuToggle.setAttribute("aria-expanded", String(Boolean(isOpen)));
      });

      menuLinks.forEach((link) => {
        link.addEventListener("click", closeMenu);
      });

      window.addEventListener("resize", () => {
        if (window.innerWidth > 920) {
          closeMenu();
        }
      });
    </script>
  </body>
</html>
